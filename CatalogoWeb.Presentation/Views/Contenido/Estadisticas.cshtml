@model EstadisticasContenido
@{ ViewData["Title"] = "Estadísticas"; }

<h1 class="mb-4">Estadísticas</h1>
<div class="row g-3">
    <div class="col-md-3"><div class="card text-center"><div class="card-body"><h5 class="card-title">Total</h5><p class="display-6">@Model.Total</p></div></div></div>
    <div class="col-md-3"><div class="card text-center"><div class="card-body"><h5 class="card-title">Películas</h5><p class="display-6">@Model.TotalPeliculas</p></div></div></div>
    <div class="col-md-3"><div class="card text-center"><div class="card-body"><h5 class="card-title">Series</h5><p class="display-6">@Model.TotalSeries</p></div></div></div>
    <div class="col-md-3"><div class="card text-center"><div class="card-body"><h5 class="card-title">Promedio calif.</h5><p class="display-6">@Model.PromedioCalificacion</p></div></div></div>
    <div class="col-md-6"><div class="card text-center border-success"><div class="card-body"><h5 class="card-title">Vistas</h5><p class="display-6 text-success">@Model.TotalVistas</p></div></div></div>
    <div class="col-md-6"><div class="card text-center border-warning"><div class="card-body"><h5 class="card-title">Pendientes</h5><p class="display-6 text-warning">@Model.TotalPendientes</p></div></div></div>
</div>