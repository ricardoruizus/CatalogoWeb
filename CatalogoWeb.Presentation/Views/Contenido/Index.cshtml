@model List<Contenido>
@{
    ViewData["Title"] = "Catálogo";
    var tipos = Enum.GetValues(typeof(TipoContenido)).Cast<TipoContenido>();
}

<h1 class="mb-4">Catálogo</h1>

<form method="get" asp-action="Index" class="row g-2 mb-4">
    <div class="col-md-4"><input type="text" name="titulo" value="@ViewBag.TituloBuscado" class="form-control" placeholder="Buscar por título..." /></div>
    <div class="col-md-3">
        <select name="tipo" class="form-select">
            <option value="">-- Todos los tipos --</option>
            @foreach (var t in tipos)
            {
                <option value="@t" selected="@(ViewBag.TipoSeleccionado?.ToString() == t.ToString())">@t</option>
            }
        </select>
    </div>
    <div class="col-md-3"><input type="text" name="genero" value="@ViewBag.GeneroBuscado" class="form-control" placeholder="Filtrar por género..." /></div>
    <div class="col-md-2"><button type="submit" class="btn btn-primary w-100">Buscar</button></div>
</form>

<a asp-action="Crear" class="btn btn-success mb-3">+ Agregar contenido</a>

<table class="table table-striped table-hover align-middle">
    <thead>
        <tr><th>Título</th><th>Tipo</th><th>Género</th><th>Año</th><th>Plataforma</th><th>Estado</th><th>Calificación</th><th>Acciones</th></tr>
    </thead>
    <tbody>
    @foreach (var item in Model)
    {
        <tr>
            <td>@item.Titulo</td>
            <td>@item.Tipo</td>
            <td>@item.Genero</td>
            <td>@item.AnioEstreno</td>
            <td>@item.Plataforma</td>
            <td><span class="badge @(item.Estado == EstadoContenido.Vista ? "bg-success" : "bg-warning text-dark")">@item.Estado</span></td>
            <td>@item.Calificacion / 5</td>
            <td>
                <a asp-action="Detalles" asp-route-id="@item.Id" class="btn btn-sm btn-outline-secondary">Ver</a>
                <a asp-action="Editar" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary">Editar</a>
                <form asp-action="CambiarEstado" asp-route-id="@item.Id" method="post" class="d-inline">
                    <input type="hidden" name="estado" value="@(item.Estado == EstadoContenido.Vista ? EstadoContenido.Pendiente : EstadoContenido.Vista)" />
                    <button type="submit" class="btn btn-sm btn-outline-success">@(item.Estado == EstadoContenido.Vista ? "Marcar pendiente" : "Marcar vista")</button>
                </form>
                <form asp-action="Eliminar" asp-route-id="@item.Id" method="post" class="d-inline" onsubmit="return confirm('¿Eliminar este registro?');">
                    <button type="submit" class="btn btn-sm btn-outline-danger">Eliminar</button>
                </form>
            </td>
        </tr>
    }
    </tbody>
</table>

@if (!Model.Any()) { <p class="text-muted">No se encontraron resultados.</p> }